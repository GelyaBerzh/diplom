<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".AddRecipeActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarAddRecipe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primaryAccent"
            app:title="@string/add_recipe_title"
            app:titleTextColor="@color/white"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="@color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:id="@+id/addRecipeRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/recipe_photo"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:paddingBottom="16dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivRecipeImage"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:layout_gravity="center_horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/recipe_photo"
                    android:padding="@dimen/recipe_image_placeholder_padding"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_camera"
                    app:strokeColor="@color/primaryAccent"
                    app:strokeWidth="2dp" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnImageAction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end|bottom"
                    android:layout_marginEnd="24dp"
                    android:layout_marginBottom="8dp"
                    android:contentDescription="@string/select_image"
                    app:backgroundTint="@color/primaryAccent"
                    app:srcCompat="@drawable/ic_camera"
                    app:tint="@color/white" />

            </FrameLayout>

            <!-- Секция: Основная информация -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Основная информация"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp"
                app:boxStrokeColor="@color/primaryAccent"
                app:hintTextColor="@color/primaryAccent"
                app:startIconTint="@color/primaryAccent"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/recipe_name"
                    android:inputType="text"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/secondaryAccent" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                app:boxStrokeColor="@color/primaryAccent"
                app:hintTextColor="@color/primaryAccent"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/recipe_description"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:gravity="top|start"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/secondaryAccent" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                app:boxStrokeColor="@color/primaryAccent"
                app:hintTextColor="@color/primaryAccent"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etInstructions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/recipe_instructions"
                    android:inputType="textMultiLine"
                    android:minLines="5"
                    android:gravity="top|start"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/secondaryAccent" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                app:boxStrokeColor="@color/primaryAccent"
                app:hintTextColor="@color/primaryAccent"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etServings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/servings_hint"
                    android:inputType="number"
                    android:text="1"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/secondaryAccent" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                app:boxStrokeColor="@color/primaryAccent"
                app:hintTextColor="@color/primaryAccent"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCookingTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/cooking_time_hint"
                    android:inputType="number"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/secondaryAccent" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Секция: Раздел блюда и способ приготовления -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tvDishType_label"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutDishType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="4dp">

                <androidx.constraintlayout.helper.widget.Flow
                    android:id="@+id/flowDishType"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:constraint_referenced_ids="cbDishCold,cbDishFirst,cbDishHot,cbDishPreserves,cbDishDessert,cbDishDrinks,cbDishSide,cbDishSauces,cbDishBakery"
                    app:flow_wrapMode="chain"
                    app:flow_horizontalGap="30dp"
                    app:flow_verticalGap="4dp"
                    app:flow_horizontalStyle="packed"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <CheckBox
                    android:id="@+id/cbDishCold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cbDishCold"
                    android:textColor="@color/textPrimary" />

                <CheckBox
                    android:id="@+id/cbDishFirst"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cbDishFirst"
                    android:textColor="@color/textPrimary" />

                <CheckBox
                    android:id="@+id/cbDishHot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cbDishHot"
                    android:textColor="@color/textPrimary" />

                <CheckBox
                    android:id="@+id/cbDishPreserves"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cbDishPreserves"
                    android:textColor="@color/textPrimary" />

                <CheckBox
                    android:id="@+id/cbDishDessert"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cbDishDessert"
                    android:textColor="@color/textPrimary" />

                <CheckBox
                    android:id="@+id/cbDishDrinks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cbDishDrinks"
                    android:textColor="@color/textPrimary" />

                <CheckBox
                    android:id="@+id/cbDishSide"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cbDishSide"
                    android:textColor="@color/textPrimary"/>

                <CheckBox
                    android:id="@+id/cbDishSauces"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cbDishSauces"
                    android:textColor="@color/textPrimary"/>

                <CheckBox
                    android:id="@+id/cbDishBakery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cbDishBakery"
                    android:textColor="@color/textPrimary"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/Cooking_Method_label"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutCookingMethod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="4dp">

                <androidx.constraintlayout.helper.widget.Flow
                    android:id="@+id/flowCookingMethod"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:constraint_referenced_ids="cbMethodPot,cbMethodPan,cbMethodmulticooker,cbMethodOven,cbMethodGrill,cbMethodblender"
                    app:flow_wrapMode="chain"
                    app:flow_horizontalGap="8dp"
                    app:flow_verticalGap="4dp"
                    app:flow_horizontalStyle="packed"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <CheckBox
                    android:id="@+id/cbMethodPot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cbMethodPot"
                    android:textColor="@color/textPrimary" />

                <CheckBox
                    android:id="@+id/cbMethodPan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cbMethodPan"
                    android:textColor="@color/textPrimary" />

                <CheckBox
                    android:id="@+id/cbMethodmulticooker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cbMethodmulticooker"
                    android:textColor="@color/textPrimary" />

                <CheckBox
                    android:id="@+id/cbMethodOven"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cbMethodOven"
                    android:textColor="@color/textPrimary" />

                <CheckBox
                    android:id="@+id/cbMethodGrill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cbMethodGrill"
                    android:textColor="@color/textPrimary" />

                <CheckBox
                    android:id="@+id/cbMethodblender"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cbMethodblender"
                    android:textColor="@color/textPrimary" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Секция: Теги -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tags_label"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp"
                android:padding="8dp"
                app:chipSpacing="8dp"
                app:chipSpacingVertical="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp"
                app:boxStrokeColor="@color/primaryAccent"
                app:hintTextColor="@color/primaryAccent"
                app:prefixText="#"
                app:prefixTextColor="@color/primaryAccent"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTagInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/tag_enter"
                    android:inputType="text"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/secondaryAccent" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/add_tag_button"
                android:layout_gravity="end"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp"
                app:backgroundTint="@color/primaryAccent"
                app:cornerRadius="8dp" />

            <!-- Секция: Ингредиенты -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ингредиенты"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp" />

            <GridLayout
                android:id="@+id/ingredientsLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="1"
                android:alignmentMode="alignMargins"
                android:useDefaultMargins="false"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:rowOrderPreserved="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddIngredient"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/add_ingredient_button"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:backgroundTint="@color/primaryAccent"
                app:cornerRadius="8dp" />

            <!-- Кнопка сохранения -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/save"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="32dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:paddingVertical="16dp"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/primaryAccent"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_save"
                app:iconTint="@color/white" />

        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>